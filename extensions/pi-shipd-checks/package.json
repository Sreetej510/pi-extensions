{
  "name": "@sreetej510/pi-shipd-checks",
  "version": "0.1.12",
  "description": "Pi extension that runs a strict, multi-agent fairness review of a benchmark task's agent_prompt.md, test.patch, and solution.patch, plus behavioral test-gap analysis, via /checks.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "review",
    "checks",
    "shipd"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "node ../../scripts/build-extension.mjs",
    "prepublishOnly": "npm run build",
    "check": "biome check . && npm run typecheck",
    "format": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typebox": "^1.3.3",
    "@biomejs/biome": "^2.5.3",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@earendil-works/pi-tui": "^0.80.3",
    "typescript": "^5.7.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Sreetej510/pi-extensions",
    "directory": "extensions/pi-shipd-checks"
  },
  "publishConfig": {
    "access": "public"
  }
}
