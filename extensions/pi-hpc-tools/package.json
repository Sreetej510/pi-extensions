{
  "name": "@sreetej510/pi-hpc-tools",
  "version": "0.1.6",
  "description": "Pi extension for exploring a remote HPC/SSH host (via plink) with ls/read/grep tools, gated per-project by /hpc:on and /hpc:off.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "hpc",
    "ssh",
    "plink",
    "remote"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "node ../../scripts/build-extension.mjs",
    "prepublishOnly": "npm run build",
    "check": "biome check . && npm run typecheck",
    "format": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typebox": "^1.3.3",
    "@biomejs/biome": "^2.5.3",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@earendil-works/pi-tui": "^0.80.3",
    "typescript": "^5.7.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Sreetej510/pi-extensions",
    "directory": "extensions/pi-hpc-tools"
  },
  "publishConfig": {
    "access": "public"
  }
}
