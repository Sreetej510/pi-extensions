{
  "name": "pi-extensions",
  "version": "0.1.1",
  "private": true,
  "packageManager": "npm@11.16.0",
  "description": "Monorepo for @sreetej510 pi extension packages.",
  "type": "module",
  "workspaces": [
    "extensions/*"
  ],
  "scripts": {
    "format": "biome format --write .",
    "lint": "biome lint .",
    "biome:check": "biome check .",
    "typecheck": "npm --workspaces run typecheck",
    "test": "npm --workspaces --if-present run test",
    "check": "npm run biome:check && npm run typecheck && npm test",
    "pack:hpc-tools": "npm --workspace @sreetej510/pi-hpc-tools pack --dry-run",
    "pack:prompt-manager": "npm --workspace @sreetej510/pi-prompt-manager pack --dry-run",
    "pack:usage": "npm --workspace @sreetej510/pi-usage pack --dry-run",
    "pack:shipd-checks": "npm --workspace @sreetej510/pi-shipd-checks pack --dry-run",
    "publish:dry": "npm --workspaces publish --dry-run --access public",
    "release:patch": "node ./scripts/bump-shared-version.mjs patch",
    "release:minor": "node ./scripts/bump-shared-version.mjs minor",
    "release:major": "node ./scripts/bump-shared-version.mjs major"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@earendil-works/pi-ai": "^0.80.3",
    "@earendil-works/pi-tui": "^0.80.3",
    "@types/node": "^22.10.0",
    "typebox": "^1.3.3",
    "typescript": "^5.7.3"
  }
}
